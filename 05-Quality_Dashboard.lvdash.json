{
  "datasets": [
    {
      "name": "437254de",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT\r\n",
        "    total_mediciones,\r\n",
        "    total_fuera_limite,\r\n",
        "    total_bajo_limite,\r\n",
        "    total_sobre_limite,\r\n",
        "    total_articulos,\r\n",
        "    total_variables,\r\n",
        "    porcentaje_fuera_limite,\r\n",
        "    fecha_minima,\r\n",
        "    fecha_maxima,\r\n",
        "    fecha_actualizacion\r\n",
        "FROM quality_data.gold.kpi_control_calidad;"
      ]
    },
    {
      "name": "ed3db78e",
      "displayName": "Variables con mas Alertas",
      "queryLines": [
        "SELECT\r\n",
        "    variable_nombre,\r\n",
        "    COUNT(*) AS total_alertas\r\n",
        "FROM quality_data.gold.alertas_calidad\r\n",
        "GROUP BY variable_nombre\r\n",
        "ORDER BY total_alertas DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "40b1de0b",
      "displayName": "Articulos Con Mas alertas",
      "queryLines": [
        "SELECT\r\n",
        "    articulo_codigo,\r\n",
        "    COUNT(*) AS total_alertas\r\n",
        "FROM quality_data.gold.alertas_calidad\r\n",
        "GROUP BY articulo_codigo\r\n",
        "ORDER BY total_alertas DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "9bac8d18",
      "displayName": "Detalle de OS fuera de control",
      "queryLines": [
        "SELECT\n",
        "  hdr AS hoja_ruta,\n",
        "  cliente_codigo,\n",
        "  articulo_codigo,\n",
        "  variable_nombre,\n",
        "  resultado_numerico,\n",
        "  limite_inferior,\n",
        "  limite_superior,\n",
        "  estado_control,\n",
        "  distancia_al_limite,\n",
        "  fecha_medicion\n",
        "FROM\n",
        "  quality_data.gold.alertas_calidad\n",
        "\n",
        "ORDER BY\n",
        "  fecha_medicion DESC,\n",
        "  hdr,\n",
        "  variable_nombre"
      ],
      "catalog": "quality_data",
      "schema": "gold"
    },
    {
      "name": "a91f9db8",
      "displayName": "Kpi2",
      "queryLines": [
        "SELECT\r\n",
        "    COUNT(DISTINCT hdr) AS total_hojas_ruta_afectadas\r\n",
        "FROM quality_data.gold.alertas_calidad;"
      ],
      "catalog": "quality_data",
      "schema": "default"
    }
  ],
